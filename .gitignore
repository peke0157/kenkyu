# =======================
# 1.データセットとモデル（絶対に公開しないもの）
# =======================
# データセットモデルのファイルを無視
data/raw/
japanese-daily-dialogue/

# ラベル付与済みデータ
data/processed/
*.csv
*.json
*.jsonl


# 音声ファイルを表す拡張子を無視
*.wav
*.mp3
*.flac
*.au
*.aac
*.m4a
*.wma

# 学習済みのモデルの重みファイル（容量が大きいため）
model/
checkpoints/
outputs/
my_custom_bert/
runs/
*.pt
*.bin
*.npy
# PyTorch
*.pth     
# TensorFlow/Keras  
*.h5        
*.onnx
# ピックルファイル（データの一時保存など）
*.pkl       


# Windowsの代替データストリーム
*:Zone.Identifier

# =======================
# 2. Python関連の不要ファイル
# =======================
__pycache__/
*.py[cod]
*$py.class

# 仮想環境のフォルダ
./venv/
venv/
env/

# 環境変数（APIキーやパスワードなどを書いたファイル）
.env


# =======================
# 3. エディタやOSの隠しファイル
# =======================
# VS Vodeの設定フォルダ
.vscode/   
# macOSのシステムファイル 
.DS_Store  
# Windowsのシステムファイル 
Thumbs.db   